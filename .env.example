DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maintenance_app?schema=public"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"
ENABLE_DEMO_ENDPOINTS="true"
GITHUB_CLIENT_ID="replace-with-github-client-id"
GITHUB_CLIENT_SECRET="replace-with-github-client-secret"
OBJECT_STORAGE_BUCKET="maintenance-app-avatars"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
OBJECT_STORAGE_ACCESS_KEY_ID="replace-with-access-key-id"
OBJECT_STORAGE_SECRET_ACCESS_KEY="replace-with-secret-access-key"
OBJECT_STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS="300"
LOG_LEVEL="info"
REQUEST_LOGS_ENABLED="true"
